---
import '@pagefind/default-ui/css/ui.css'
---

<site-search>
  <aside class='form my-4'>
    {
      import.meta.env.DEV ? (
        <div class='w-full rounded-xl border-2 bg-transparent px-4 py-2 pe-3 outline-none focus:border-foreground'>
          You are in Dev mode, the search is disabled.
        </div>
      ) : (
        <div id='site-search' />
      )
    }
  </aside>
</site-search>

<script>
  class SiteSearch extends HTMLElement {
    constructor() {
      super()
      // const shouldStrip = this.dataset.stripTrailingSlash !== undefined
      // const stripTrailingSlash = (path: string) => path.replace(/(.)\/(#.*)?$/, '$1$2')
      // const formatURL = shouldStrip ? stripTrailingSlash : (path: string) => path
      const formatURL = (path: string) => path.replace(/(.)\/(#.*)?$/, '$1$2')

      window.addEventListener('DOMContentLoaded', () => {
        // if (import.meta.env.DEV) return
        const onIdle = window.requestIdleCallback || ((cb) => setTimeout(cb, 1))
        onIdle(async () => {
          // @ts-expect-error — Missing types for @pagefind/default-ui package.
          const { PagefindUI } = await import('@pagefind/default-ui')
          new PagefindUI({
            element: '#site-search',
            baseUrl: import.meta.env.BASE_URL,
            bundlePath: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/pagefind/`,
            showImages: false,
            showSubResults: true,
            openFilters: ['tag'],
            processResult: (result: { url: string; sub_results: Array<{ url: string }> }) => {
              result.url = formatURL(result.url)
              result.sub_results = result.sub_results.map((sub_result) => {
                sub_result.url = formatURL(sub_result.url)
                return sub_result
              })
            }
          })
          // Extract the count from each value's label text ("ai (5)" → 5) and stash it
          // on the value element as a `data-count` attribute so CSS can hide 0-count
          // items by default, and show them again when a tag is actively selected.
          const setDataCount = () => {
            document
              .querySelectorAll('.pagefind-ui__filter-group')
              .forEach((filterGroup) => {
                filterGroup
                  .querySelectorAll<HTMLElement>('.pagefind-ui__filter-value')
                  .forEach((valueEl) => {
                    if (valueEl.dataset.allOption !== undefined) {
                      valueEl.dataset.count = String(Number.MAX_SAFE_INTEGER)
                      return
                    }
                    const label = valueEl.querySelector('.pagefind-ui__filter-label')
                    if (!label) return
                    const match = label.textContent?.match(/\((\d+)\)/)
                    valueEl.dataset.count = match ? match[1] : '0'
                  })
              })
          }
          // Toggle `.show-all-tags` on the filter group whenever any non-"All" radio
          // is currently checked — CSS then reveals the 0-count tags so the user can
          // jump between tags without losing visibility of alternatives.
          const updateShowAllTags = () => {
            document
              .querySelectorAll('.pagefind-ui__filter-group')
              .forEach((filterGroup) => {
                const firstRadio = filterGroup.querySelector<HTMLInputElement>(
                  'input[type="radio"]'
                )
                if (!firstRadio) return
                const filterName = firstRadio.name
                const anyTagSelected = Array.from(
                  filterGroup.querySelectorAll<HTMLInputElement>(
                    `input[name="${filterName}"]`
                  )
                ).some((radio) => radio.checked)
                filterGroup.classList.toggle('show-all-tags', anyTagSelected)
              })
          }
          // Convert filter checkboxes to radio buttons for single-select tag switching.
          // HTML radios only emit `change` on the newly-checked one, so we dispatch
          // `change` on the previously-checked siblings to keep PagefindUI's
          // `selected_filters` in sync (otherwise stale `true` entries remain).
          const toRadio = () => {
            document
              .querySelectorAll<HTMLInputElement>('.pagefind-ui__filter-checkbox')
              .forEach((el) => {
                if (el.type === 'radio' || el.dataset.radioConverted) return
                el.type = 'radio'
                el.dataset.radioConverted = 'true'
                el.addEventListener('change', () => {
                  if (!el.checked) return
                  document
                    .querySelectorAll<HTMLInputElement>(`input[name="${el.name}"]`)
                    .forEach((other) => {
                      if (other !== el && other.checked) {
                        other.checked = false
                        other.dispatchEvent(new Event('change'))
                      }
                    })
                  // Tag selected: drop the "All" checked styling and reveal 0-count tags
                  const filterGroup = el.closest('.pagefind-ui__filter-group')
                  const allOption = filterGroup?.querySelector('[data-all-option]')
                  allOption?.classList.remove('pagefind-ui__filter-value--checked')
                  filterGroup?.classList.add('show-all-tags')
                })
              })
          }
          // Inject a clickable "All" pill at the top of every filter group. It's a
          // plain <div> (not a real radio) so clicking it doesn't add a `__all__`
          // entry to PagefindUI's `selected_filters` — we just clear the actual tag
          // radios via the same dispatch trick, then refresh the visual state.
          const addAllOption = () => {
            document.querySelectorAll('.pagefind-ui__filter-group').forEach((filterGroup) => {
              if (filterGroup.querySelector('[data-all-option]')) return
              const firstRadio = filterGroup.querySelector<HTMLInputElement>(
                'input[type="radio"]'
              )
              if (!firstRadio) return
              const filterName = firstRadio.name
              const hasSelectedTag = Array.from(
                filterGroup.querySelectorAll<HTMLInputElement>(
                  `input[name="${filterName}"]`
                )
              ).some((radio) => radio.checked)

              const container = document.createElement('div')
              container.className = 'pagefind-ui__filter-value'
              container.dataset.allOption = 'true'
              container.dataset.count = String(Number.MAX_SAFE_INTEGER)
              container.innerHTML = `<span class="pagefind-ui__filter-label">All</span>`
              filterGroup.insertBefore(container, filterGroup.firstChild)
              if (!hasSelectedTag) {
                container.classList.add('pagefind-ui__filter-value--checked')
              }

              container.addEventListener('click', () => {
                // Uncheck all real tag radios (skip the fake "All" div)
                document
                  .querySelectorAll<HTMLInputElement>(`input[name="${filterName}"]`)
                  .forEach((other) => {
                    if (other.checked) {
                      other.checked = false
                      other.dispatchEvent(new Event('change'))
                    }
                  })
                // Restore the "All" visual state and hide 0-count tags again
                container.classList.add('pagefind-ui__filter-value--checked')
                filterGroup.classList.remove('show-all-tags')
              })
            })
          }
          const setupFilters = () => {
            toRadio()
            addAllOption()
            setDataCount()
            updateShowAllTags()
          }
          const siteSearch = document.querySelector('#site-search')
          if (siteSearch) {
            setupFilters()
            new MutationObserver(setupFilters).observe(siteSearch, {
              childList: true,
              subtree: true
            })
          }
        })
      })
    }
  }
  customElements.define('site-search', SiteSearch)
</script>

<style>
  #site-search {
    --pagefind-ui-scale: 0.8;
    --pagefind-ui-primary: hsl(var(--primary) / var(--un-bg-opacity, 1));
    --pagefind-ui-text: hsl(var(--foreground) / var(--un-text-opacity, 1));
    --pagefind-ui-background: hsl(var(--muted) / var(--un-bg-opacity, 1));
    --pagefind-ui-border: hsl(var(--border) / var(--un-border-opacity, 1));
    --pagefind-ui-tag: hsl(var(--muted-foreground) / var(--un-text-opacity, 1));
    --pagefind-ui-border-width: 2px;
    --pagefind-ui-border-radius: calc(var(--radius) + 2px);
    --pagefind-ui-image-border-radius: calc(var(--radius) + 2px);
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: sans-serif;
  }

  /* Hide 0-count tag values by default; reveal them when a tag is actively selected
     so users can pivot between tags without losing visibility of alternatives. */
  #site-search .pagefind-ui__filter-value[data-count='0']:not([data-all-option]) {
    display: none;
  }
  #site-search .pagefind-ui__filter-group.show-all-tags .pagefind-ui__filter-value[data-count='0']:not([data-all-option]) {
    display: flex;
  }
</style>
