---
import '@pagefind/default-ui/css/ui.css'
---

<site-search>
  <aside class='form my-4'>
    {
      import.meta.env.DEV ? (
        <div class='w-full rounded-xl border-2 bg-transparent px-4 py-2 pe-3 outline-none focus:border-foreground'>
          You are in Dev mode, the search is disabled.
        </div>
      ) : (
        <div id='site-search' />
      )
    }
  </aside>
</site-search>

<script>
  class SiteSearch extends HTMLElement {
    constructor() {
      super()
      // const shouldStrip = this.dataset.stripTrailingSlash !== undefined
      // const stripTrailingSlash = (path: string) => path.replace(/(.)\/(#.*)?$/, '$1$2')
      // const formatURL = shouldStrip ? stripTrailingSlash : (path: string) => path
      const formatURL = (path: string) => path.replace(/(.)\/(#.*)?$/, '$1$2')

      window.addEventListener('DOMContentLoaded', () => {
        // if (import.meta.env.DEV) return
        const onIdle = window.requestIdleCallback || ((cb) => setTimeout(cb, 1))
        onIdle(async () => {
          // @ts-expect-error — Missing types for @pagefind/default-ui package.
          const { PagefindUI } = await import('@pagefind/default-ui')
          new PagefindUI({
            element: '#site-search',
            baseUrl: import.meta.env.BASE_URL,
            bundlePath: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/pagefind/`,
            showImages: false,
            showSubResults: true,
            openFilters: ['tag'],
            processResult: (result: { url: string; sub_results: Array<{ url: string }> }) => {
              result.url = formatURL(result.url)
              result.sub_results = result.sub_results.map((sub_result) => {
                sub_result.url = formatURL(sub_result.url)
                return sub_result
              })
            }
          })

          // Track the last seen search query so we can re-record the "stable" tag
          // count when the user types something new. The stable count is the
          // per-tag result count under the current query *without* any tag filter
          // applied — Pagefind's UI re-renders this on tag selection (it shows
          // "if you switched to this tag, you'd get N results") which we don't
          // want. We cache the query-only version and overwrite Pagefind's
          // recomputed label.
          let lastQuery = ''
          const getCurrentQuery = () =>
            (document.querySelector<HTMLInputElement>('.pagefind-ui__search-input')?.value ?? '')

          // Read each value's count from its label ("ai (5)" → 5), then either
          // (a) cache it as the new stable count when the query changes (or no
          // tag is currently selected), or (b) overwrite Pagefind's recomputed
          // count with the cached stable count when a tag is selected. The
          // stable count is mirrored to `data-count` so CSS can hide 0-count
          // tags.
          const setStableCount = (isNewQuery: boolean) => {
            document.querySelectorAll('.pagefind-ui__filter-group').forEach((filterGroup) => {
              const anyTagChecked =
                filterGroup.querySelector<HTMLInputElement>('input[type="radio"]:checked') !== null

              filterGroup
                .querySelectorAll<HTMLElement>('.pagefind-ui__filter-value')
                .forEach((valueEl) => {
                  const label = valueEl.querySelector<HTMLElement>('.pagefind-ui__filter-label')
                  if (!label) return
                  const match = label.textContent?.match(/\((\d+)\)/)
                  if (!match) return
                  const currentCount = match[1]

                  if (isNewQuery || !anyTagChecked) {
                    valueEl.dataset.originalCount = currentCount
                  }

                  const originalCount = valueEl.dataset.originalCount ?? currentCount
                  if (originalCount !== currentCount) {
                    label.textContent = label.textContent.replace(
                      `(${currentCount})`,
                      `(${originalCount})`
                    )
                  }
                  valueEl.dataset.count = originalCount
                })
            })
          }

          // Convert filter checkboxes to radio buttons for single-select tag
          // switching, and let the user deselect by clicking the active radio a
          // second time (HTML radios don't auto-deselect on re-click). The
          // click handler works for clicks on both the input itself and the
          // associated <label>: at the moment the click event reaches the
          // input, `el.checked` is still the pre-click value, so seeing `true`
          // unambiguously means "this radio is already selected — deselect it".
          // HTML radios only emit `change` on the newly-checked one, so we
          // dispatch `change` on the previously-checked siblings to keep
          // PagefindUI's `selected_filters` in sync (otherwise stale `true`
          // entries remain and zero out results).
          const toRadio = () => {
            document
              .querySelectorAll<HTMLInputElement>('.pagefind-ui__filter-checkbox')
              .forEach((el) => {
                if (el.type === 'radio' || el.dataset.radioConverted) return
                el.type = 'radio'
                el.dataset.radioConverted = 'true'

                el.addEventListener('click', (e) => {
                  if (!el.checked) return
                  e.preventDefault()
                  el.checked = false
                  el.dispatchEvent(new Event('change'))
                })

                el.addEventListener('change', () => {
                  if (el.checked) {
                    // Tag selected: clear any previously-checked siblings.
                    document
                      .querySelectorAll<HTMLInputElement>(`input[name="${el.name}"]`)
                      .forEach((other) => {
                        if (other !== el && other.checked) {
                          other.checked = false
                          other.dispatchEvent(new Event('change'))
                        }
                      })
                  }
                  // Re-record stable count under the new selected/cleared state.
                  setStableCount(false)
                })
              })
          }

          const setupFilters = () => {
            toRadio()
            const isNewQuery = getCurrentQuery() !== lastQuery
            lastQuery = getCurrentQuery()
            setStableCount(isNewQuery)
          }
          const siteSearch = document.querySelector('#site-search')
          if (siteSearch) {
            setupFilters()
            new MutationObserver(setupFilters).observe(siteSearch, {
              childList: true,
              subtree: true
            })
          }
        })
      })
    }
  }
  customElements.define('site-search', SiteSearch)
</script>

<style is:global>
  #site-search {
    --pagefind-ui-scale: 0.8;
    --pagefind-ui-primary: hsl(var(--primary) / var(--un-bg-opacity, 1));
    --pagefind-ui-text: hsl(var(--foreground) / var(--un-text-opacity, 1));
    --pagefind-ui-background: hsl(var(--muted) / var(--un-bg-opacity, 1));
    --pagefind-ui-border: hsl(var(--border) / var(--un-border-opacity, 1));
    --pagefind-ui-tag: hsl(var(--muted-foreground) / var(--un-text-opacity, 1));
    --pagefind-ui-border-width: 2px;
    --pagefind-ui-border-radius: calc(var(--radius) + 2px);
    --pagefind-ui-image-border-radius: calc(var(--radius) + 2px);
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: sans-serif;
  }

  /* Always hide 0-count tag values. The PagefindUI child DOM is injected at
     runtime and lacks Astro's scoped `data-astro-cid-xxx` attribute, so the
     entire style block is marked `is:global`. */
  #site-search .pagefind-ui__filter-value[data-count='0'] {
    display: none;
  }
</style>
</content>
</invoke>