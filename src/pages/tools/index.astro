---
import PageLayout from '@/layouts/BaseLayout.astro'

import './tools.css'

const title = 'Tools'
---

<PageLayout meta={{ title }}>
  <main class='flex w-full flex-col items-center px-4 py-8'>
    <div class='w-full max-w-5xl bg-background border rounded-lg shadow-sm'>
      <!-- 导航栏 -->
      <nav class='flex border-b border-border'>
        <button
          data-tab='format'
          class='tab-button flex-1 py-3 px-6 text-sm font-medium transition-colors'
        >
          字符串格式化
        </button>
        <button
          data-tab='timestamp'
          class='tab-button flex-1 py-3 px-6 text-sm font-medium transition-colors'
        >
          时间戳转换
        </button>
      </nav>

      <!-- 字符串格式化内容 -->
      <div id='tab-format' class='tab-content p-6'>
        <!-- 格式选择和按钮 -->
        <div class='mb-4 flex items-center gap-4'>
          <label class='block text-sm font-medium mb-2 min-w-[80px]'>字符串格式</label>
          <div class='flex gap-4'>
            <label class='flex items-center gap-2 cursor-pointer'>
              <input type='radio' name='format-type' value='protobuf' checked class='w-4 h-4' />
              <span>Protobuf</span>
            </label>
            <label class='flex items-center gap-2 cursor-pointer'>
              <input type='radio' name='format-type' value='json' class='w-4 h-4' />
              <span>JSON</span>
            </label>
            <label class='flex items-center gap-2 cursor-pointer'>
              <input type='radio' name='format-type' value='xml' class='w-4 h-4' />
              <span>XML</span>
            </label>
            <label class='flex items-center gap-2 cursor-pointer'>
              <input type='radio' name='format-type' value='kotlin-data' class='w-4 h-4' />
              <span>Kotlin Data</span>
            </label>
          </div>
          <div class='flex gap-2 ml-auto'>
            <button
              id='format-btn'
              class='px-3 py-1 text-xs bg-gray-200 hover:bg-gray-300 rounded text-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-200'
            >
              格式化
            </button>
            <button
              id='clear-btn'
              class='px-3 py-1 text-xs bg-gray-200 hover:bg-gray-300 rounded text-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-200'
            >
              清空
            </button>
          </div>
        </div>

        <!-- 搜索框和匹配信息 -->
        <div class='mb-4 flex gap-4'>
          <div class='flex-1'>
            <label class='block text-sm font-medium mb-2'>搜索</label>
            <input
              type='text'
              id='search-input'
              placeholder=''
              class='w-full px-4 py-2 border border-border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500'
            />
          </div>
          <div class='flex items-end pb-2 gap-2'>
            <span id='match-info' class='text-sm text-muted-foreground'>0 / 0</span>
            <button
              id='search-next-btn'
              class='px-3 py-1 text-xs bg-gray-200 hover:bg-gray-300 rounded text-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-200'
            >
              下一个
            </button>
          </div>
        </div>

        <!-- 文本区域 -->
        <div class='mb-4'>
          <label class='block text-sm font-medium mb-2'>文本</label>
          <div
            class='flex border border-gray-300 rounded-md overflow-hidden'
            style='height: 520px;'
          >
            <!-- 行号区域 -->
            <div
              id='line-numbers'
              class='bg-gray-100 text-gray-500 text-right pr-2 py-2 font-mono text-sm select-none'
            >
            </div>
            <!-- 文本框 -->
            <textarea
              id='text-input'
              rows='20'
              placeholder=''
              class='flex-1 px-4 py-2 border-0 focus:outline-none focus:ring-0 font-mono resize-none overflow-y-auto'
              style='height: 100%;'></textarea>
          </div>
        </div>
      </div>

      <!-- 时间戳转换内容 -->
      <div id='tab-timestamp' class='tab-content p-6 hidden'>
        <!-- 当前时间戳 -->
        <div class='mb-6'>
          <div class='flex flex-col gap-2'>
            <h3 class='text-lg font-medium'>当前时间戳</h3>
            <div class='flex items-center justify-between'>
              <p class='text-sm'>秒级时间戳：<span id='current-timestamp-seconds'></span></p>
              <button
                id='copy-seconds-btn'
                class='px-3 py-1 text-xs bg-gray-200 hover:bg-gray-300 rounded text-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-200'
              >
                复制
              </button>
            </div>
            <div class='flex items-center justify-between'>
              <p class='text-sm'>
                毫秒级时间戳：<span id='current-timestamp-milliseconds'></span>
              </p>
              <button
                id='copy-milliseconds-btn'
                class='px-3 py-1 text-xs bg-gray-200 hover:bg-gray-300 rounded text-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-200'
              >
                复制
              </button>
            </div>
          </div>
        </div>

        <!-- 时间戳转时间 -->
        <div class='mb-6'>
          <div class='flex items-center gap-4 mb-6'>
            <h3 class='text-lg font-medium'>时间戳转时间</h3>
            <input
              type='text'
              id='timestamp-input'
              placeholder='输入秒级或毫秒级时间戳'
              class='flex-1 px-4 py-2 border border-border rounded-md bg-background text-foreground'
            />
          </div>
          <div class='flex flex-col gap-2'>
            <p class='text-sm'>GMT 时间：<span id='gmt-time'></span></p>
            <p class='text-sm'>东八区时间：<span id='cst-time'></span></p>
            <p class='text-sm'>相对时间：<span id='relative-time'></span></p>
          </div>
        </div>

        <!-- 时间转时间戳 -->
        <div class='mb-6'>
          <div class='flex items-center gap-4 mb-6'>
            <h3 class='text-lg font-medium'>时间转时间戳</h3>
            <input
              type='datetime-local'
              id='datetime-input'
              class='flex-1 px-4 py-2 border border-border rounded-md bg-background text-foreground'
            />
          </div>
          <div class='flex flex-col gap-2'>
            <p class='text-sm'>秒级时间戳：<span id='converted-timestamp-seconds'></span></p>
            <p class='text-sm'>毫秒级时间戳：<span id='converted-timestamp-milliseconds'></span></p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script src='./main.ts'></script>
</PageLayout>
