---
import PageLayout from '@/layouts/BaseLayout.astro'

const title = 'Tools'
---

<PageLayout meta={{ title }}>
  <main class='flex w-full flex-col items-center px-4 py-8'>
    <div class='w-full max-w-5xl bg-background border rounded-lg shadow-sm'>
      <!-- 导航栏 -->
      <nav class='flex border-b border-border'>
        <button
          data-tab='format'
          class='tab-button flex-1 py-3 px-6 text-sm font-medium transition-colors'
        >
          字符串格式化
        </button>
        <button
          data-tab='timestamp'
          class='tab-button flex-1 py-3 px-6 text-sm font-medium transition-colors'
        >
          时间戳转换
        </button>
      </nav>

      <!-- 字符串格式化内容 -->
      <div id='tab-format' class='tab-content p-6'>
        <!-- 格式选择和按钮 -->
        <div class='mb-4 flex items-center gap-4'>
          <label class='block text-sm font-medium mb-2 min-w-[80px]'>字符串格式</label>
          <div class='flex gap-4'>
            <label class='flex items-center gap-2 cursor-pointer'>
              <input type='radio' name='format-type' value='protobuf' checked class='w-4 h-4' />
              <span>Protobuf</span>
            </label>
            <label class='flex items-center gap-2 cursor-pointer'>
              <input type='radio' name='format-type' value='json' class='w-4 h-4' />
              <span>JSON</span>
            </label>
            <label class='flex items-center gap-2 cursor-pointer'>
              <input type='radio' name='format-type' value='xml' class='w-4 h-4' />
              <span>XML</span>
            </label>
          </div>
          <div class='flex gap-2 ml-auto'>
            <button
              id='format-btn'
              class='px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors text-sm'
            >
              格式化
            </button>
            <button
              id='clear-btn'
              class='px-6 py-2 bg-gray-600 text-white rounded-md hover:bg-gray-700 transition-colors text-sm'
            >
              清空
            </button>
          </div>
        </div>

        <!-- 搜索框和匹配信息 -->
        <div class='mb-4 flex gap-4'>
          <div class='flex-1'>
            <label class='block text-sm font-medium mb-2'>搜索</label>
            <input
              type='text'
              id='search-input'
              placeholder=''
              class='w-full px-4 py-2 border border-border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500'
            />
          </div>
          <div class='flex items-end pb-2 gap-2'>
            <span id='match-info' class='text-sm text-muted-foreground'>0 / 0</span>
            <button
              id='search-next-btn'
              class='px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors text-sm'
            >
              下一个
            </button>
          </div>
        </div>

        <!-- 文本区域 -->
        <div class='mb-4'>
          <label class='block text-sm font-medium mb-2'>文本</label>
          <div
            class='flex border border-gray-300 rounded-md overflow-hidden'
            style='height: 520px;'
          >
            <!-- 行号区域 -->
            <div
              id='line-numbers'
              class='bg-gray-100 text-gray-500 text-right pr-2 py-2 font-mono text-sm select-none'
            >
            </div>
            <!-- 文本框 -->
            <textarea
              id='text-input'
              rows='20'
              placeholder=''
              class='flex-1 px-4 py-2 border-0 focus:outline-none focus:ring-0 font-mono resize-none overflow-y-auto'
              style='height: 100%;'></textarea>
          </div>
        </div>
      </div>

      <!-- 时间戳转换内容 -->
      <div id='tab-timestamp' class='tab-content p-6 hidden'>
        <!-- 当前时间戳 -->
        <div class='mb-6'>
          <div class='flex flex-col gap-2'>
            <h3 class='text-lg font-medium'>当前时间戳</h3>
            <div class='flex items-center justify-between'>
              <p class='text-sm'>秒级时间戳：<span id='current-timestamp-seconds'></span></p>
              <button
                id='copy-seconds-btn'
                class='px-3 py-1 text-xs bg-gray-200 hover:bg-gray-300 rounded text-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-200'
              >
                复制
              </button>
            </div>
            <div class='flex items-center justify-between'>
              <p class='text-sm'>
                毫秒级时间戳：<span id='current-timestamp-milliseconds'></span>
              </p>
              <button
                id='copy-milliseconds-btn'
                class='px-3 py-1 text-xs bg-gray-200 hover:bg-gray-300 rounded text-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-200'
              >
                复制
              </button>
            </div>
          </div>
        </div>

        <!-- 时间戳转时间 -->
        <div class='mb-6'>
          <div class='flex items-center gap-4 mb-6'>
            <h3 class='text-lg font-medium'>时间戳转时间</h3>
            <input
              type='text'
              id='timestamp-input'
              placeholder='输入秒级或毫秒级时间戳'
              class='flex-1 px-4 py-2 border border-border rounded-md bg-background text-foreground'
            />
          </div>
          <div class='flex flex-col gap-2'>
            <p class='text-sm'>GMT 时间：<span id='gmt-time'></span></p>
            <p class='text-sm'>东八区时间：<span id='cst-time'></span></p>
            <p class='text-sm'>相对时间：<span id='relative-time'></span></p>
          </div>
        </div>

        <!-- 时间转时间戳 -->
        <div class='mb-6'>
          <div class='flex items-center gap-4 mb-6'>
            <h3 class='text-lg font-medium'>时间转时间戳</h3>
            <input
              type='datetime-local'
              id='datetime-input'
              class='flex-1 px-4 py-2 border border-border rounded-md bg-background text-foreground'
            />
          </div>
          <div class='flex flex-col gap-2'>
            <p class='text-sm'>秒级时间戳：<span id='converted-timestamp-seconds'></span></p>
            <p class='text-sm'>毫秒级时间戳：<span id='converted-timestamp-milliseconds'></span></p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    const formatBtn = document.getElementById('format-btn')
    const clearBtn = document.getElementById('clear-btn')
    const searchInput = document.getElementById('search-input') as HTMLInputElement
    const searchNextBtn = document.getElementById('search-next-btn')
    const textInput = document.getElementById('text-input') as HTMLTextAreaElement
    const lineNumbers = document.getElementById('line-numbers')
    const matchInfo = document.getElementById('match-info') as HTMLSpanElement
    const formatRadios = document.querySelectorAll(
      "input[name='format-type']"
    ) as NodeListOf<HTMLInputElement>
    const tabButtons = document.querySelectorAll('.tab-button')
    const tabContents = document.querySelectorAll('.tab-content')

    // 页签切换
    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const tabName = (button as HTMLElement).dataset.tab
        tabButtons.forEach((btn) => {
          btn.classList.remove('border-b-2', 'border-blue-600', 'text-blue-600')
        })
        tabContents.forEach((content) => content.classList.add('hidden'))
        button.classList.add('border-b-2', 'border-blue-600', 'text-blue-600')
        document.getElementById(`tab-${tabName}`)?.classList.remove('hidden')
        // 切换页签时清除搜索状态
        searchInput.value = ''
        matchInfo.textContent = '0 / 0'
        allMatches = []
      })
    })

    // 初始化选中第一个页签
    tabButtons[0].classList.add('border-b-2', 'border-blue-600', 'text-blue-600')
    document.getElementById('tab-format')?.classList.remove('hidden')
    document.getElementById('tab-timestamp')?.classList.add('hidden')

    // 清空按钮
    clearBtn.addEventListener('click', () => {
      textInput.value = ''
      searchInput.value = ''
      matchInfo.textContent = '0 / 0'
    })

    // 切换字符串格式时清空文本框
    formatRadios.forEach((radio) => {
      radio.addEventListener('change', () => {
        textInput.value = ''
        searchInput.value = ''
        matchInfo.textContent = '0 / 0'
      })
    })

    // 文本框输入时自动格式化（防抖）
    let formatDebounceTimer: ReturnType<typeof setTimeout>
    textInput.addEventListener('input', () => {
      clearTimeout(formatDebounceTimer)
      formatDebounceTimer = setTimeout(() => {
        if (textInput.value.trim()) {
          formatBtn.click()
        }
      }, 1000) // 1秒防抖
    })

    // 格式化按钮
    formatBtn.addEventListener('click', () => {
      const formatType = Array.from(formatRadios).find((radio) => radio.checked)?.value
      const text = textInput.value

      if (!text.trim()) {
        alert('请输入要格式化的文本')
        return
      }

      try {
        switch (formatType) {
          case 'json':
            formatJSON()
            break
          case 'xml':
            formatXML()
            break
          case 'protobuf':
            formatProtobuf()
            break
          default:
            alert('请选择格式化类型')
        }
        // 格式化后清除搜索
        searchInput.value = ''
        matchInfo.textContent = '0 / 0'
        // 文本框滚动到顶部
        textInput.scrollTop = 0
        // 更新行号
        updateLineNumbers()
      } catch (error) {
        alert('格式化失败：' + (error as Error).message)
      }
    })

    // JSON 格式化
    function formatJSON() {
      try {
        const parsed = JSON.parse(textInput.value)
        textInput.value = JSON.stringify(parsed, null, 2)
      } catch {
        alert('无效的 JSON 格式')
      }
    }

    // XML 格式化
    function formatXML() {
      try {
        const text = textInput.value.trim()
        if (!text) {
          alert('请输入 XML 内容')
          return
        }

        // 简单的XML格式化逻辑，不依赖DOMParser
        let indent = 0
        let result = ''
        let inTag = false
        let tagContent = ''

        for (let i = 0; i < text.length; i++) {
          const char = text[i]

          if (char === '<') {
            if (tagContent.trim()) {
              result += '  '.repeat(indent) + tagContent.trim() + '\n'
              tagContent = ''
            }
            inTag = true
            tagContent += char
          } else if (char === '>') {
            tagContent += char
            inTag = false

            // 检查是否是闭合标签
            if (tagContent.startsWith('</')) {
              indent--
              result += '  '.repeat(indent) + tagContent + '\n'
            } else if (tagContent.endsWith('/>')) {
              // 自闭合标签
              result += '  '.repeat(indent) + tagContent + '\n'
            } else {
              // 开始标签
              result += '  '.repeat(indent) + tagContent + '\n'
              indent++
            }
            tagContent = ''
          } else if (inTag) {
            tagContent += char
          } else {
            tagContent += char
          }
        }

        // 处理剩余内容
        if (tagContent.trim()) {
          result += '  '.repeat(indent) + tagContent.trim() + '\n'
        }

        textInput.value = result
      } catch (error) {
        alert('无效的 XML 格式')
      }
    }

    // Protobuf 格式化
    function formatProtobuf() {
      const text = textInput.value.trim()
      if (!text) {
        alert('请输入 Protobuf 内容')
        return
      }

      try {
        const formatted = formatProtobufMessage(text)
        textInput.value = formatted
      } catch (error) {
        alert('格式化失败：' + (error as Error).message)
      }
    }

    // 格式化 Protobuf 消息内容（处理日志格式）
    function formatProtobufMessage(text: string): string {
      // 提取 -> 和 | 之间的内容
      const match = text.match(/->\s*(.*?)\s*\|/s)
      const protobufContent = match ? match[1] : text

      // 按大括号和分号分割内容，保持键值对的完整性
      const result: string[] = []
      let indent = 0
      let currentLine = ''

      // 按字符处理，保持键值对的完整性
      let i = 0
      while (i < protobufContent.length) {
        const char = protobufContent[i]

        if (char === ' ') {
          // 跳过空格
          if (currentLine) {
            currentLine += ' '
          }
          i++
        } else if (char === '{') {
          if (currentLine) {
            result.push('  '.repeat(indent) + currentLine.trim() + ' {')
            currentLine = ''
          } else {
            result.push('  '.repeat(indent) + '{')
          }
          indent++
          i++
        } else if (char === '}') {
          if (currentLine) {
            result.push('  '.repeat(indent) + currentLine.trim())
            currentLine = ''
          }
          indent--
          result.push('  '.repeat(indent) + '}')
          i++
        } else if (char === ';') {
          currentLine += char
          result.push('  '.repeat(indent) + currentLine.trim())
          currentLine = ''
          i++
        } else {
          currentLine += char
          i++
        }
      }

      // 添加最后一行（如果有）
      if (currentLine.trim()) {
        result.push('  '.repeat(indent) + currentLine.trim())
      }

      return result.join('\n')
    }

    // 搜索相关
    let currentMatchIndex = 0
    let allMatches: RegExpMatchArray | null = null

    // 输入事件（防抖）
    let debounceTimer: ReturnType<typeof setTimeout>
    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer)
      debounceTimer = setTimeout(() => {
        performSearch()
      }, 300)
    })

    // 回车键跳转到匹配项
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault()
        // 如果还没有匹配项，先执行搜索
        if (!allMatches || allMatches.length === 0) {
          performSearch()
        }
        // 显示当前匹配项（从第一个开始）
        showHighlightAndScroll()
        // 更新显示
        updateMatchDisplay()
        // 准备下一次跳转
        currentMatchIndex = (currentMatchIndex + 1) % allMatches.length
      }
    })

    // 搜索按钮点击事件
    searchNextBtn?.addEventListener('click', () => {
      // 如果还没有匹配项，先执行搜索
      if (!allMatches || allMatches.length === 0) {
        performSearch()
      }
      // 显示当前匹配项
      showHighlightAndScroll()
      // 更新显示
      updateMatchDisplay()
      // 准备下一次跳转
      currentMatchIndex = (currentMatchIndex + 1) % allMatches.length
    })

    function performSearch() {
      const searchText = searchInput.value.trim()
      const text = textInput.value
      allMatches = searchText
        ? text.match(new RegExp(searchText.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'))
        : null
      currentMatchIndex = 0
      updateMatchDisplay()
    }

    function moveToNextMatch() {
      if (!allMatches || allMatches.length === 0) {
        return
      }

      // 显示当前匹配项
      showHighlightAndScroll()
      // 更新显示
      updateMatchDisplay()
      // 准备下一次跳转
      currentMatchIndex = (currentMatchIndex + 1) % allMatches.length
    }

    function updateMatchDisplay() {
      if (!allMatches || allMatches.length === 0) {
        matchInfo.textContent = '0 / 0'
        return
      }

      // 显示当前匹配项的序号（从1开始）
      const currentDisplayIndex = (currentMatchIndex % allMatches.length) + 1
      matchInfo.textContent = `${currentDisplayIndex} / ${allMatches.length}`
    }

    function showHighlightAndScroll() {
      const text = textInput.value
      const searchPattern = searchInput.value.trim()

      if (!searchPattern) {
        return
      }

      // 找到匹配项的位置，使用非全局正则表达式避免lastIndex问题
      const regex = new RegExp(searchPattern.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi')
      regex.lastIndex = 0 // 重置lastIndex

      let match
      let matches = []
      while ((match = regex.exec(text)) !== null) {
        matches.push({ start: match.index, end: match.index + match[0].length })
        // 避免无限循环
        if (match.index === regex.lastIndex) {
          regex.lastIndex++
        }
      }

      // 如果有匹配项，显示高亮并滚动
      if (matches.length > 0) {
        const targetIndex = currentMatchIndex % matches.length
        const targetMatch = matches[targetIndex]

        // 聚焦文本框以显示选择
        textInput.focus()
        textInput.setSelectionRange(targetMatch.start, targetMatch.end)

        // 滚动到匹配项位置
        textInput.scrollTop = Math.max(
          0,
          (targetMatch.start / text.length) * textInput.scrollHeight - textInput.clientHeight / 2
        )
      }
    }

    // 更新行号
    function updateLineNumbers() {
      if (!lineNumbers || !textInput) return

      const text = textInput.value
      // 计算行数，空字符串算一行
      const lineCount = text ? text.split('\n').length : 1
      let lineNumbersText = ''
      for (let i = 1; i <= lineCount; i++) {
        lineNumbersText += i + '\n'
      }
      lineNumbers.textContent = lineNumbersText
    }

    // 同步滚动
    function syncScroll() {
      if (!lineNumbers || !textInput) return
      lineNumbers.scrollTop = textInput.scrollTop
    }

    // 文本框事件监听
    textInput.addEventListener('input', updateLineNumbers)
    textInput.addEventListener('scroll', syncScroll)

    // 时间戳转换功能
    const currentTimestampSeconds = document.getElementById('current-timestamp-seconds')
    const currentTimestampMilliseconds = document.getElementById('current-timestamp-milliseconds')
    const copySecondsBtn = document.getElementById('copy-seconds-btn')
    const copyMillisecondsBtn = document.getElementById('copy-milliseconds-btn')
    const timestampInput = document.getElementById('timestamp-input') as HTMLInputElement
    const gmtTime = document.getElementById('gmt-time')
    const cstTime = document.getElementById('cst-time')
    const relativeTime = document.getElementById('relative-time')
    const datetimeInput = document.getElementById('datetime-input') as HTMLInputElement
    const convertedTimestampSeconds = document.getElementById('converted-timestamp-seconds')
    const convertedTimestampMilliseconds = document.getElementById(
      'converted-timestamp-milliseconds'
    )

    // 格式化时间为指定格式
    function formatDateTime(date: Date): string {
      const year = date.getFullYear()
      const month = String(date.getMonth() + 1).padStart(2, '0')
      const day = String(date.getDate()).padStart(2, '0')
      const hours = String(date.getHours()).padStart(2, '0')
      const minutes = String(date.getMinutes()).padStart(2, '0')
      const seconds = String(date.getSeconds()).padStart(2, '0')
      const milliseconds = String(date.getMilliseconds()).padStart(3, '0')
      return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}.${milliseconds}`
    }

    // 动态更新当前时间戳
    function updateCurrentTimestamp() {
      const now = Date.now()
      const seconds = Math.floor(now / 1000)
      if (currentTimestampSeconds) currentTimestampSeconds.innerHTML = seconds.toString()
      if (currentTimestampMilliseconds) currentTimestampMilliseconds.innerHTML = now.toString()
    }

    // 初始化当前时间
    function initCurrentDate() {
      const now = new Date()
      // 格式化为datetime-local输入框的格式：YYYY-MM-DDTHH:mm
      const year = now.getFullYear()
      const month = String(now.getMonth() + 1).padStart(2, '0')
      const day = String(now.getDate()).padStart(2, '0')
      const hours = String(now.getHours()).padStart(2, '0')
      const minutes = String(now.getMinutes()).padStart(2, '0')
      if (datetimeInput) {
        datetimeInput.value = `${year}-${month}-${day}T${hours}:${minutes}`
      }
    }

    // 获取当前浏览器时区
    function getBrowserTimezone() {
      return Intl.DateTimeFormat().resolvedOptions().timeZone
    }

    // 获取时区偏移（分钟）
    function getTimezoneOffset() {
      return new Date().getTimezoneOffset()
    }

    // 时间戳转时间
    function timestampToTime(timestamp: string) {
      if (!timestamp) {
        if (gmtTime) gmtTime.innerHTML = ''
        if (cstTime) cstTime.innerHTML = ''
        if (relativeTime) relativeTime.innerHTML = ''
        return
      }

      let ts = parseInt(timestamp)
      // 自动识别秒级或毫秒级时间戳
      if (ts.toString().length === 10) {
        ts *= 1000
      }

      const date = new Date(ts)

      // GMT时间（UTC时间）
      if (gmtTime) {
        const gmtDate = new Date(date.getTime() + date.getTimezoneOffset() * 60000)
        gmtTime.innerHTML = formatDateTime(gmtDate)
      }

      // 东八区时间（UTC+8）
      if (cstTime) {
        const cstDate = new Date(date.getTime() + (8 * 60 + date.getTimezoneOffset()) * 60000)
        cstTime.innerHTML = formatDateTime(cstDate)
      }

      // 相对时间
      const now = Date.now()
      const diff = now - ts
      const absDiff = Math.abs(diff)

      let relativeStr = ''
      const oneMinute = 60000
      const oneHour = 3600000
      const oneDay = 86400000
      const oneWeek = 604800000
      const fourWeeks = 2419200000 // 4周 = 28天
      const oneMonth = 2592000000 // 平均每月30天
      const oneYear = 31536000000

      if (absDiff < oneMinute) {
        relativeStr = `${Math.floor(absDiff / 1000)}秒`
      } else if (absDiff < oneHour) {
        relativeStr = `${Math.floor(absDiff / oneMinute)}分钟`
      } else if (absDiff < oneDay) {
        relativeStr = `${Math.floor(absDiff / oneHour)}小时`
      } else if (absDiff < oneWeek) {
        relativeStr = `${Math.floor(absDiff / oneDay)}天`
      } else if (absDiff < fourWeeks) {
        relativeStr = `${Math.floor(absDiff / oneWeek)}周`
      } else if (absDiff < oneYear) {
        relativeStr = `${Math.floor(absDiff / oneMonth)}月`
      } else {
        relativeStr = `${Math.floor(absDiff / oneYear)}年`
      }

      relativeStr = diff > 0 ? `${relativeStr}前` : `${relativeStr}后`
      if (relativeTime) relativeTime.innerHTML = relativeStr
    }

    // 时间转时间戳
    function timeToTimestamp() {
      if (!datetimeInput) return

      const datetimeValue = datetimeInput.value
      if (!datetimeValue) {
        if (convertedTimestampSeconds) convertedTimestampSeconds.innerHTML = ''
        if (convertedTimestampMilliseconds) convertedTimestampMilliseconds.innerHTML = ''
        return
      }

      const date = new Date(datetimeValue)
      const timestampSeconds = Math.floor(date.getTime() / 1000)
      const timestampMilliseconds = date.getTime()

      if (convertedTimestampSeconds)
        convertedTimestampSeconds.innerHTML = timestampSeconds.toString()
      if (convertedTimestampMilliseconds)
        convertedTimestampMilliseconds.innerHTML = timestampMilliseconds.toString()
    }

    // 显示提示信息
    function showToast(message: string) {
      // 创建提示元素
      const toast = document.createElement('div')
      toast.className =
        'fixed top-4 right-4 px-4 py-2 bg-blue-600 text-white rounded-md shadow-lg z-50'
      toast.textContent = message
      document.body.appendChild(toast)

      // 显示动画
      toast.style.opacity = '0'
      toast.style.transform = 'translateY(-20px)'
      toast.style.transition = 'opacity 0.3s, transform 0.3s'

      setTimeout(() => {
        toast.style.opacity = '1'
        toast.style.transform = 'translateY(0)'
      }, 10)

      // 3秒后消失
      setTimeout(() => {
        toast.style.opacity = '0'
        toast.style.transform = 'translateY(-20px)'
        setTimeout(() => {
          document.body.removeChild(toast)
        }, 300)
      }, 3000)
    }

    // 复制功能
    function copyToClipboard(text: string) {
      console.log('复制文本:', text)
      if (!text) {
        showToast('没有可复制的内容')
        return
      }

      // 尝试使用navigator.clipboard API
      if (navigator.clipboard) {
        navigator.clipboard
          .writeText(text)
          .then(() => {
            console.log('复制成功')
            showToast('复制成功！')
          })
          .catch((err) => {
            console.error('复制失败:', err)
            // 尝试使用传统的复制方法
            fallbackCopyTextToClipboard(text)
          })
      } else {
        // 浏览器不支持navigator.clipboard API
        fallbackCopyTextToClipboard(text)
      }
    }

    // 传统的复制方法作为 fallback
    function fallbackCopyTextToClipboard(text: string) {
      const textArea = document.createElement('textarea')
      textArea.value = text

      // 避免滚动到元素
      textArea.style.top = '0'
      textArea.style.left = '0'
      textArea.style.position = 'fixed'

      document.body.appendChild(textArea)
      textArea.focus()
      textArea.select()

      try {
        const successful = document.execCommand('copy')
        if (successful) {
          showToast('复制成功！')
        } else {
          showToast('复制失败，请手动复制')
        }
      } catch (err) {
        console.error('复制失败:', err)
        showToast('复制失败，请手动复制')
      } finally {
        document.body.removeChild(textArea)
      }
    }

    // 事件监听
    if (timestampInput) {
      timestampInput.addEventListener('input', () => {
        timestampToTime(timestampInput.value)
      })
    }

    if (datetimeInput) {
      datetimeInput.addEventListener('input', timeToTimestamp)
    }

    // 复制按钮事件监听
    if (copySecondsBtn) {
      copySecondsBtn.addEventListener('click', () => {
        if (currentTimestampSeconds) {
          copyToClipboard(currentTimestampSeconds.textContent || '')
        }
      })
    }

    if (copyMillisecondsBtn) {
      copyMillisecondsBtn.addEventListener('click', () => {
        if (currentTimestampMilliseconds) {
          copyToClipboard(currentTimestampMilliseconds.textContent || '')
        }
      })
    }

    // 初始化
    searchInput.value = ''
    matchInfo.textContent = '0 / 0'
    updateLineNumbers()
    updateCurrentTimestamp()
    initCurrentDate()
    timeToTimestamp() // 初始化时间转时间戳

    // 每秒钟更新一次当前时间戳
    setInterval(updateCurrentTimestamp, 1000)
  </script>

