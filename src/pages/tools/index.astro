---
import PageLayout from '@/layouts/BaseLayout.astro'

const title = 'Tools'
---

<PageLayout meta={{ title }}>
  <main class='flex w-full flex-col items-center px-4 py-8'>
    <div class='w-full max-w-4xl bg-background border rounded-lg shadow-sm'>
      <!-- 导航栏 -->
      <nav class='flex border-b border-border'>
        <button
          data-tab='format'
          class='tab-button flex-1 py-3 px-6 text-sm font-medium transition-colors'
        >
          字符串格式化
        </button>
        <button
          data-tab='encoder'
          class='tab-button flex-1 py-3 px-6 text-sm font-medium transition-colors'
        >
          URL 编码
        </button>
      </nav>

      <!-- 字符串格式化内容 -->
      <div id='tab-format' class='tab-content p-6'>
        <!-- 格式选择和按钮 -->
        <div class='mb-4 flex items-center gap-4'>
          <label class='block text-sm font-medium mb-2 min-w-[80px]'>字符串格式</label>
          <div class='flex gap-4'>
            <label class='flex items-center gap-2 cursor-pointer'>
              <input type='radio' name='format-type' value='json' checked class='w-4 h-4' />
              <span>JSON</span>
            </label>
            <label class='flex items-center gap-2 cursor-pointer'>
              <input type='radio' name='format-type' value='xml' class='w-4 h-4' />
              <span>XML</span>
            </label>
            <label class='flex items-center gap-2 cursor-pointer'>
              <input type='radio' name='format-type' value='protobuf' class='w-4 h-4' />
              <span>Protobuf</span>
            </label>
          </div>
          <div class='flex gap-2 ml-auto'>
            <button
              id='format-btn'
              class='px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors text-sm'
            >
              格式化
            </button>
            <button
              id='clear-btn'
              class='px-6 py-2 bg-gray-600 text-white rounded-md hover:bg-gray-700 transition-colors text-sm'
            >
              清空
            </button>
          </div>
        </div>

        <!-- 搜索框和匹配信息 -->
        <div class='mb-4 flex gap-4'>
          <div class='flex-1'>
            <label class='block text-sm font-medium mb-2'>搜索</label>
            <input
              type='text'
              id='search-input'
              placeholder='输入要搜索的文本... (回车跳转下一处)'
              class='w-full px-4 py-2 border border-border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500'
            />
          </div>
          <div class='flex items-end pb-2'>
            <span id='match-info' class='text-sm text-muted-foreground'>0 / 0</span>
          </div>
        </div>

        <!-- 文本区域 -->
        <div class='mb-4'>
          <label class='block text-sm font-medium mb-2'>文本</label>
          <textarea
            id='text-input'
            rows='20'
            placeholder='在此粘贴文本...'
            class='w-full px-4 py-2 border border-border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono text-sm resize-y'
          ></textarea>
        </div>
      </div>

      <!-- URL 编码内容（占位） -->
      <div id='tab-encoder' class='tab-content p-6 hidden'>
        <p class='text-muted-foreground'>URL 编码功能正在开发中...</p>
      </div>
    </div>
  </main>

  <script>
    const formatBtn = document.getElementById('format-btn')
    const clearBtn = document.getElementById('clear-btn')
    const searchInput = document.getElementById('search-input') as HTMLInputElement
    const textInput = document.getElementById('text-input') as HTMLTextAreaElement
    const matchInfo = document.getElementById('match-info') as HTMLSpanElement
    const formatRadios = document.querySelectorAll(
      "input[name='format-type']"
    ) as NodeListOf<HTMLInputElement>
    const tabButtons = document.querySelectorAll('.tab-button')
    const tabContents = document.querySelectorAll('.tab-content')

    // 页签切换
    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const tabName = button.dataset.tab
        tabButtons.forEach((btn) => {
          btn.classList.remove('border-b-2', 'border-blue-600', 'text-blue-600')
        })
        tabContents.forEach((content) => content.classList.add('hidden'))
        button.classList.add('border-b-2', 'border-blue-600', 'text-blue-600')
        document.getElementById(`tab-${tabName}`)?.classList.remove('hidden')
        // 切换页签时清除搜索状态
        searchInput.value = ''
        matchInfo.textContent = '0 / 0'
      })
    })

    // 初始化选中第一个页签
    tabButtons[0].classList.add('border-b-2', 'border-blue-600', 'text-blue-600')
    document.getElementById('tab-format')?.classList.remove('hidden')

    // 清空按钮
    clearBtn.addEventListener('click', () => {
      textInput.value = ''
      searchInput.value = ''
      matchInfo.textContent = '0 / 0'
    })

    // 格式化按钮
    formatBtn.addEventListener('click', () => {
      const formatType = Array.from(formatRadios).find((radio) => radio.checked)?.value
      const text = textInput.value

      if (!text.trim()) {
        alert('请输入要格式化的文本')
        return
      }

      try {
        switch (formatType) {
          case 'json':
            formatJSON()
            break
          case 'xml':
            formatXML()
            break
          case 'protobuf':
            formatProtobuf()
            break
        }
        // 格式化后清除搜索
        searchInput.value = ''
        matchInfo.textContent = '0 / 0'
      } catch (error) {
        alert('格式化失败：' + (error as Error).message)
      }
    })

    // JSON 格式化
    function formatJSON() {
      try {
        const parsed = JSON.parse(textInput.value)
        textInput.value = JSON.stringify(parsed, null, 2)
      } catch {
        alert('无效的 JSON 格式')
      }
    }

    // XML 格式化
    function formatXML() {
      try {
        const parser = new DOMParser()
        const xmlDoc = parser.parseFromString(textInput.value, 'text/xml')

        if (xmlDoc.querySelector('parsererror')) {
          throw new Error('无效的 XML 格式')
        }

        const serializer = new XMLSerializer()
        const formatted = serializer.serializeToString(xmlDoc)

        textInput.value = formatXMLIndent(formatted)
      } catch (error) {
        alert('无效的 XML 格式')
      }
    }

    // 格式化 XML 缩进（改进版）
    function formatXMLIndent(xml: string): string {
      const lines = xml.split('\n')
      const result: string[] = []
      let indentLevel = 0
      const indentSize = 2

      for (let i = 0; i < lines.length; i++) {
        const line = lines[i]
        const trimmed = line.trim()

        // 跳过空行
        if (!trimmed) {
          result.push('')
          continue
        }

        // 计算缩进级别
        const openTagMatch = trimmed.match(/^<\/?(\w+)/)
        if (openTagMatch) {
          const tagName = openTagMatch[1]

          // 检查是否是闭合标签
          if (trimmed.startsWith('</')) {
            indentLevel--
          } else if (!trimmed.endsWith('/>')) {
            // 不是自闭合标签，增加缩进
            indentLevel++
          }
        }

        // 添加缩进
        const indent = '  '.repeat(indentLevel)
        result.push(indent + trimmed)
      }

      return result.join('\n')
    }

    // Protobuf 格式化
    function formatProtobuf() {
      const text = textInput.value.trim()
      if (!text) {
        alert('请输入 Protobuf 内容')
        return
      }

      try {
        const formatted = formatProtobufMessage(text)
        textInput.value = formatted
      } catch (error) {
        alert('格式化失败：' + (error as Error).message)
      }
    }

    // 格式化 Protobuf 消息内容（只包含消息定义，去掉其他内容）
    function formatProtobufMessage(text: string): string {
      const lines = text.split('\n')
      const result: string[] = []
      let indent = 0
      let inMessage = false

      for (const line of lines) {
        const trimmedLine = line.trim()

        // 跳过空行
        if (!trimmedLine) {
          continue
        }

        // 检测消息开始
        if (trimmedLine.startsWith('message ')) {
          inMessage = true
          result.push(''.repeat(indent) + trimmedLine)
          indent++
        }
        // 检测消息结束
        else if (trimmedLine === '}') {
          indent--
          inMessage = false
        }
        // 只在消息块内处理字段
        else if (inMessage) {
          // 检测字段定义
          const fieldMatch = trimmedLine.match(
            /^(repeated|required|optional)\s+(\w+)\s+(\w+)\s*=\s*(\d+)(?:;\s*\/\/\s*(.+))?/
          )
          if (fieldMatch) {
            const [, type, name, number, comment] = fieldMatch
            result.push(
              ''.repeat(indent) +
                `${type} ${typeMap[type]} ${name} = ${number}; // ${comment || ''}`
            )
          }
          // 检测枚举值
          else if (trimmedLine.match(/^  \w+\s*=\s*\d+;$/)) {
            result.push(''.repeat(indent) + trimmedLine)
          }
          // 检测嵌套消息开始
          else if (trimmedLine.startsWith('message ')) {
            result.push(''.repeat(indent) + trimmedLine)
            indent++
          }
          // 检测嵌套消息结束
          else if (trimmedLine === '}') {
            indent--
          }
          // 其他行（如注释）直接保留
          else if (trimmedLine.startsWith('//') || trimmedLine.startsWith('#')) {
            result.push(''.repeat(indent) + trimmedLine)
          }
          // 忽略其他内容
        }
      }

      return result.join('\n')
    }

    // Protobuf 类型映射
    const typeMap: Record<string, string> = {
      int32: 'int32',
      int64: 'int64',
      uint32: 'uint32',
      uint64: 'uint64',
      sint32: 'sint32',
      sint64: 'sint64',
      fixed32: 'fixed32',
      fixed64: 'fixed64',
      sfixed32: 'sfixed32',
      sfixed64: 'sfixed64',
      float: 'float',
      double: 'double',
      bool: 'bool',
      string: 'string',
      bytes: 'bytes'
    }

    // 搜索相关
    let currentMatchIndex = 0
    let allMatches: RegExpMatchArray | null = null

    // 输入事件（防抖）
    let debounceTimer: ReturnType<typeof setTimeout>
    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer)
      debounceTimer = setTimeout(() => {
        performSearch()
      }, 300)
    })

    // 回车键跳转到下一个匹配项
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault()
        moveToNextMatch()
      }
    })

    function performSearch() {
      const searchText = searchInput.value.trim()
      const text = textInput.value
      allMatches = searchText
        ? text.match(new RegExp(searchText.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'))
        : null
      currentMatchIndex = 0
      updateMatchDisplay()
    }

    function moveToNextMatch() {
      if (!allMatches || allMatches.length === 0) {
        return
      }

      currentMatchIndex = (currentMatchIndex + 1) % allMatches.length
      highlightMatch(allMatches[currentMatchIndex])
    }

    function updateMatchDisplay() {
      if (!allMatches || allMatches.length === 0) {
        matchInfo.textContent = '0 / 0'
        return
      }

      matchInfo.textContent = `${currentMatchIndex + 1} / ${allMatches.length}`
    }

    function highlightMatch(matchText: string) {
      const text = textInput.value
      const searchPattern = searchInput.value.trim()

      if (!searchPattern) {
        textInput.value = text
        return
      }

      // 创建高亮标记
      const regex = new RegExp(
        searchPattern.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'),
        'gi'
      )

      // 替换所有匹配项为高亮格式
      textInput.value = text.replace(regex, (match) => {
        return `<mark class="bg-yellow-200 dark:bg-yellow-900/50 px-1 rounded">${match}</mark>`
      })
    }

    // 初始化
    searchInput.value = ''
    matchInfo.textContent = '0 / 0'
  </script>

  <style>
    .tab-button {
      border-bottom: 2px solid transparent;
    }

    .tab-button:hover {
      background-color: rgba(0, 0, 0, 0.05);
    }

    .tab-button.active {
      border-bottom-color: #2563eb;
      color: #2563eb;
    }

    mark {
      font-weight: 500;
    }
  </style>
</PageLayout>
